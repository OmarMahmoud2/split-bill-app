require "fileutils"
require "shellwords"

default_platform(:ios)

PROJECT_ROOT = File.expand_path("..", __dir__)
PUBSPEC_PATH = File.join(PROJECT_ROOT, "pubspec.yaml")
VERSION_MATCH = File.read(PUBSPEC_PATH).match(/^version:\s*([0-9A-Za-z.\-]+)\+(\d+)\s*$/)

UI.user_error!("Could not read app version from #{PUBSPEC_PATH}") unless VERSION_MATCH

APP_VERSION = VERSION_MATCH[1]
BUILD_NUMBER = VERSION_MATCH[2]
RELEASE_NOTES = "UI Improvements and Bug Fixes"
SYMBOLS_DIR = File.join(PROJECT_ROOT, "build", "symbols", "#{APP_VERSION}+#{BUILD_NUMBER}")
ANDROID_AAB = File.join(PROJECT_ROOT, "build", "app", "outputs", "bundle", "release", "app-release.aab")
IOS_IPA = File.join(PROJECT_ROOT, "build", "ios", "ipa", "split_bill_app.ipa")
IOS_METADATA_PATH = File.join(PROJECT_ROOT, "fastlane", "metadata")
IOS_FILTERED_METADATA_PATH = File.join(PROJECT_ROOT, "build", "fastlane", "ios_metadata")
IOS_APP_IDENTIFIER = ENV.fetch("APP_IDENTIFIER", "com.example.splitBillApp")
IOS_APP_STORE_LOCALES = %w[
  ar-SA de-DE en-AU en-CA en-GB en-US es-ES es-MX fr-CA fr-FR
  hi id it ja ko pl pt-BR pt-PT ru zh-Hans zh-Hant
]

def app_store_api_key
  app_store_connect_api_key(
    key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
    issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
    key_filepath: ENV["APP_STORE_CONNECT_API_KEY_KEY_FILEPATH"],
    in_house: false
  )
end

def run_flutter_build(args)
  FileUtils.mkdir_p(SYMBOLS_DIR)
  Dir.chdir(PROJECT_ROOT) do
    sh(args.shelljoin)
  end
end

def build_android_aab
  run_flutter_build([
    "flutter",
    "build",
    "aab",
    "--release",
    "--obfuscate",
    "--split-debug-info=#{SYMBOLS_DIR}",
    "--build-name=#{APP_VERSION}",
    "--build-number=#{BUILD_NUMBER}"
  ])
  ensure_file_exists!(ANDROID_AAB, "Android App Bundle was not produced.")
end

def build_ios_ipa
  run_flutter_build([
    "flutter",
    "build",
    "ipa",
    "--release",
    "--obfuscate",
    "--split-debug-info=#{SYMBOLS_DIR}",
    "--build-name=#{APP_VERSION}",
    "--build-number=#{BUILD_NUMBER}"
  ])
  ensure_file_exists!(IOS_IPA, "iOS IPA was not produced.")
end

def ensure_file_exists!(path, message)
  UI.user_error!("#{message} Missing: #{path}") unless File.exist?(path)
end

def option_enabled?(value)
  [true, "true", "1", "yes", "y"].include?(value)
end

def ios_locales
  IOS_APP_STORE_LOCALES.select { |locale| File.directory?(File.join(IOS_METADATA_PATH, locale)) }
end

def ios_release_notes
  ios_locales.to_h { |locale| [locale, RELEASE_NOTES] }
end

def prepare_ios_metadata_path
  FileUtils.rm_rf(IOS_FILTERED_METADATA_PATH)
  FileUtils.mkdir_p(IOS_FILTERED_METADATA_PATH)

  ios_locales.each do |locale|
    FileUtils.cp_r(
      File.join(IOS_METADATA_PATH, locale),
      File.join(IOS_FILTERED_METADATA_PATH, locale)
    )
  end

  IOS_FILTERED_METADATA_PATH
end

def ios_submission_information
  {
    export_compliance_uses_encryption: false
  }
end

def ios_deliver_options(api_key)
  {
    api_key: api_key,
    app_version: APP_VERSION,
    skip_screenshots: true,
    skip_metadata: false,
    force: true,
    run_precheck_before_submit: false,
    ignore_language_directory_validation: true,
    metadata_path: prepare_ios_metadata_path,
    release_notes: ios_release_notes
  }
end

def ios_app_store_version
  app = Spaceship::ConnectAPI::App.find(IOS_APP_IDENTIFIER)
  UI.user_error!("Could not find App Store Connect app for #{IOS_APP_IDENTIFIER}") unless app

  versions = app.get_app_store_versions(
    filter: { platform: Spaceship::ConnectAPI::Platform::IOS },
    includes: "appStoreVersionLocalizations"
  )
  version = versions.find { |candidate| candidate.version_string == APP_VERSION }
  UI.user_error!("Could not find iOS App Store version #{APP_VERSION}") unless version

  version
end

def ensure_ios_whats_new!
  version = ios_app_store_version
  localizations = version.get_app_store_version_localizations
  by_locale = localizations.each_with_object({}) { |localization, result| result[localization.locale] = localization }

  updated = []
  missing = []

  ios_release_notes.each do |locale, notes|
    localization = by_locale[locale]
    if localization
      next if localization.whats_new.to_s.strip == notes

      localization.update(attributes: { whats_new: notes })
      updated << locale
    else
      missing << locale
    end
  end

  UI.success("Updated iOS What's New for #{updated.size} locale(s).") if updated.any?
  UI.important("No iOS What's New changes were needed.") if updated.empty?
  UI.important("Locale(s) not currently on the App Store version: #{missing.join(', ')}") if missing.any?
end

platform :ios do
  desc "Build the obfuscated iOS IPA for the current pubspec version"
  lane :build_ipa do
    build_ios_ipa
    UI.success("Built IPA for #{APP_VERSION}+#{BUILD_NUMBER}: #{IOS_IPA}")
  end

  desc "Push iOS localized metadata and What's New text to App Store Connect"
  lane :upload_metadata do
    api_key = app_store_api_key
    deliver(
      ios_deliver_options(api_key).merge(
        overwrite_screenshots: false,
        submit_for_review: false,
        skip_binary_upload: true
      )
    )
    ensure_ios_whats_new!
  end

  desc "Patch What's New, select the uploaded build, and submit it for App Store review"
  lane :submit_existing do
    api_key = app_store_api_key
    ensure_ios_whats_new!

    deliver(
      ios_deliver_options(api_key).merge(
        build_number: BUILD_NUMBER,
        skip_binary_upload: true,
        skip_metadata: true,
        skip_screenshots: true,
        submit_for_review: true,
        automatic_release: option_enabled?(ENV.fetch("IOS_AUTOMATIC_RELEASE", "false")),
        submission_information: ios_submission_information
      )
    )
  end

  desc "Build, upload, and submit the iOS app version for App Store review"
  lane :release do |options|
    build_ios_ipa unless option_enabled?(options[:skip_build])
    ensure_file_exists!(IOS_IPA, "Run `fastlane ios build_ipa` first, or omit skip_build.")

    api_key = app_store_api_key
    deliver(
      ios_deliver_options(api_key).merge(
        ipa: IOS_IPA,
        overwrite_screenshots: false,
        submit_for_review: false
      )
    )

    ensure_ios_whats_new!

    deliver(
      ios_deliver_options(api_key).merge(
        build_number: BUILD_NUMBER,
        skip_binary_upload: true,
        skip_metadata: true,
        skip_screenshots: true,
        submit_for_review: true,
        automatic_release: option_enabled?(ENV.fetch("IOS_AUTOMATIC_RELEASE", "false")),
        submission_information: ios_submission_information
      )
    )
  end
end

platform :android do
  desc "Build the obfuscated Android App Bundle for the current pubspec version"
  lane :build_aab do
    build_android_aab
    UI.success("Built AAB for #{APP_VERSION}+#{BUILD_NUMBER}: #{ANDROID_AAB}")
  end

  desc "Push Android localized metadata to Google Play Console"
  lane :upload_metadata do
    supply(
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true,
      metadata_path: "fastlane/metadata/android"
    )
  end

  desc "Build, upload, and submit the Android app bundle to Google Play"
  lane :release do |options|
    build_android_aab unless option_enabled?(options[:skip_build])
    ensure_file_exists!(ANDROID_AAB, "Run `fastlane android build_aab` first, or omit skip_build.")

    supply(
      track: ENV.fetch("ANDROID_TRACK", "production"),
      aab: ANDROID_AAB,
      metadata_path: "fastlane/metadata/android",
      skip_upload_metadata: false,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: false,
      release_status: ENV.fetch("ANDROID_RELEASE_STATUS", "completed"),
      changes_not_sent_for_review: false
    )
  end

  desc "Alias for android release"
  lane :deploy do |options|
    release(skip_build: options[:skip_build])
  end
end
